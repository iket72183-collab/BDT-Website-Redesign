# BDT Connect — mobile environment.
# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# Expo only exposes vars prefixed EXPO_PUBLIC_* to the client bundle.
# These are wired into app.json -> expo.extra (stripePublishableKey, apiUrl).

# Stripe publishable key, test mode (pk_test_...). Used by <StripeProvider>
# at the app root. The public-booking API also returns a publishable key
# per booking, which usePaymentSheet uses for PaymentSheet init.
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxx

# Backend API base URL. apps/api defaults to port 4000 (API_PORT in apps/api).
EXPO_PUBLIC_API_URL=http://localhost:4000

# Sentry DSN (https://...@o.../...). Leave blank to disable crash reporting
# (Sentry.init no-ops when DSN is empty). Set the real DSN in EAS env for
# preview + production builds. Sourcemap upload at build time additionally
# needs SENTRY_AUTH_TOKEN, SENTRY_ORG, and SENTRY_PROJECT — those live in the
# EAS build env, NOT the EXPO_PUBLIC_* namespace (don't ship the auth token).
EXPO_PUBLIC_SENTRY_DSN=
