{
  "$schema": "https://schema.railpack.com",
  "steps": {
    "build": {
      "inputs": [{ "step": "install" }],
      "commands": [
        "pnpm --filter @bdt/api db:migrate",
        "pnpm --filter @bdt/api build"
      ]
    }
  },
  "deploy": {
    "startCommand": "pnpm --filter @bdt/api start"
  }
}
