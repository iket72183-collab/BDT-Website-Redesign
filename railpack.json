{
  "$schema": "https://schema.railpack.com",
  "steps": {
    "install": {
      "inputs": [
        { "local": true, "include": ["."] },
        { "step": "packages:mise" }
      ],
      "commands": [
        "corepack enable",
        "corepack prepare pnpm@9.12.0 --activate",
        "pnpm install --frozen-lockfile"
      ]
    },
    "build": {
      "inputs": [{ "step": "install" }],
      "commands": [
        "pnpm --filter @bdt/api db:migrate",
        "pnpm --filter @bdt/api build"
      ]
    }
  },
  "deploy": {
    "startCommand": "pnpm --filter @bdt/api start"
  }
}
