# =============================================================================
# BDT Connect — environment variables
# Copy to `.env` and fill in. Never commit `.env`.
# =============================================================================

# --- Runtime ---
NODE_ENV=development

# --- API ---
API_PORT=4000
API_PUBLIC_URL=http://localhost:4000

# --- Database ---
DATABASE_URL=postgresql://bdt_app:bdt_app@localhost:5432/bdt_connect
DATABASE_MAX_CONNECTIONS=10

# --- Auth ---
# Generate each with: openssl rand -base64 48
#
# JWT_SECRET is the legacy single key; access + refresh fall back to it when
# the per-token secrets below are unset. For production, set distinct values
# for ACCESS_TOKEN_SECRET and REFRESH_TOKEN_SECRET so a leak of one can't be
# replayed against the other. Rotating either invalidates all existing
# tokens of that type, forcing users to log back in.
JWT_SECRET=replace-me-with-a-long-random-string
ACCESS_TOKEN_SECRET=
REFRESH_TOKEN_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# --- Stripe ---
# Test keys from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Webhook signing secret for `/api/webhooks/stripe`. Register the endpoint
# in Stripe Dashboard → Webhooks; copy the signing secret here.
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs for the two subscription tiers.
# Create in Stripe Dashboard → Products:
#   - BDT Connect Basic   — $100.00/month recurring, 14-day trial
#   - BDT Connect Premium — $175.00/month recurring, 14-day trial
STRIPE_BASIC_PRICE_ID=price_...
STRIPE_PREMIUM_PRICE_ID=price_...

# --- Mobile app ---
# Read by Expo at build time. Must be prefixed EXPO_PUBLIC_ to be exposed.
EXPO_PUBLIC_API_URL=http://localhost:4000
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# --- Email (Resend) ---
# https://resend.com — free tier covers ~3k emails/month, ~100/day.
# 1. Create account, add + verify your sending domain.
# 2. Generate an API key at https://resend.com/api-keys
# 3. Set RESEND_FROM to a `Name <address@your-verified-domain>` value.
# In dev (NODE_ENV != production), sendEmail() just logs — these can be blank.
RESEND_API_KEY=re_...
RESEND_FROM=BDT Connect <noreply@bdtconnect.com>

# Where email links (reset password / verify email) deep-link the user back to.
PUBLIC_APP_URL=http://localhost:3000

# --- CORS (production) ---
# Comma-separated list of origins allowed to call the API with credentials.
# Leave blank in dev — the server reflects any origin. In production, list
# every domain that needs access (admin dashboard, marketing site, etc.).
# Mobile app does not need to be listed — native apps don't send Origin.
ALLOWED_ORIGINS=

# --- Social-account credential vault ---
# AES-256 master key for encrypting the social-media logins some clients hand
# over (delegated access is preferred; this is the fallback). Base64 of exactly
# 32 bytes. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Leave BLANK to disable the vault — credential storage then returns
# `vault_unavailable` and only delegated / create-for-me flows work. Store the
# real value in your host secret manager (Railway), never in the repo.
SOCIAL_VAULT_KEY=

# --- File storage (Supabase Storage) ---
# Object storage for client request attachments. Create a Supabase project +
# a Storage bucket, then set these. Optional: when unset, the upload endpoint
# returns `storage_unavailable` (503) and the rest of the API runs fine.
# SUPABASE_SERVICE_ROLE_KEY is a server-only secret — never expose it to clients.
# The bucket should be public (attachment URLs open directly in the browser), or
# switch uploadService to on-read signed URLs for a private bucket.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=request-attachments

# --- Observability ---
SENTRY_DSN=
LOG_LEVEL=info
# Populated by Railway / CI from the deployed commit SHA. Surfaced via /health.
APP_VERSION=

# --- Background jobs (BullMQ + Redis) ---
# The worker process (apps/api/worker.ts) consumes the `platform-events` queue
# (audit/analytics writes + delayed Expo push-receipt checks).
REDIS_URL=redis://localhost:6379
WORKER_CONCURRENCY=5
